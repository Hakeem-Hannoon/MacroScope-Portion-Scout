{
  "expo": {
    "name": "Portion Estimation Demo",
    "slug": "ppe-demo",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "ios": {
      "bundleIdentifier": "com.spotterlabs.ppedemo",
      "infoPlist": {
        "NSCameraUsageDescription": "The camera measures your meal with an AR ruler to estimate portions."
      }
    },
    "android": {
      "package": "com.spotterlabs.ppedemo"
    },
    "plugins": [
      "expo-asset",
      "expo-font",
      "./plugins/with-fmt-xcode26-fix.js",
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "16.0"
          }
        }
      ]
    ]
  }
}
